    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"import matplotlib.pyplot as plt\\\\n\\\",\\n\",\n",
    "    \"    \\\"import numpy as np\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# -------------------------- 1. 设置全局绘图参数（科研级配置） --------------------------\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 设置默认字体（Arial是科研期刊常用字体，无衬线更清晰）\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['font.family'] = 'Arial'\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['font.size'] = 12  # 基础字体大小\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['axes.linewidth'] = 1.2  # 坐标轴线条宽度\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['figure.dpi'] = 300  # 画布默认清晰度\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['savefig.dpi'] = 300  # 保存图片的清晰度\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['axes.unicode_minus'] = False  # 解决负号显示问题\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# -------------------------- 2. 定义5组示例数组（替换为你的真实数据） --------------------------\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 示例：5组长度不同的数组，你可以替换成自己的实际数据\\\\n\\\",\\n\",\n",
    "    \"    \\\"arr1 = np.array(energy_2)\\\\n\\\",\\n\",\n",
    "    \"    \\\"arr2 = np.array(energy_3)\\\\n\\\",\\n\",\n",
    "    \"    \\\"arr3 = np.array(energy_4)\\\\n\\\",\\n\",\n",
    "    \"    \\\"arr4 = np.array(energy_5)\\\\n\\\",\\n\",\n",
    "    \"    \\\"arr5 = np.array(energy_6)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 整理成列表，方便遍历\\\\n\\\",\\n\",\n",
    "    \"    \\\"data_list = [arr1, arr2, arr3, arr4, arr5]\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 定义每组的label（替换为你的实际分组名称）\\\\n\\\",\\n\",\n",
    "    \"    \\\"labels = ['L=2', 'L=3', 'L=4', 'L=5', 'L=6']\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# -------------------------- 3. 科研常用配色（Nature/Science期刊风格） --------------------------\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 颜色选择原则：对比度高、无荧光色、适合黑白打印识别，避免红绿色盲不友好的组合\\\\n\\\",\\n\",\n",
    "    \"    \\\"colors = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd']  # 蓝、橙、绿、红、紫（科研经典配色）\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# -------------------------- 4. 绘图核心逻辑 --------------------------\\\\n\\\",\\n\",\n",
    "    \"    \\\"fig, ax = plt.subplots(figsize=(8, 6))  # 设置画布大小（宽10英寸，高6英寸）\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 遍历每组数据绘制曲线\\\\n\\\",\\n\",\n",
    "    \"    \\\"for i, arr in enumerate(data_list):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    # 根据数组长度生成对应的x轴数据\\\\n\\\",\\n\",\n",
    "    \"    \\\"    x = np.arange(len(arr))\\\\n\\\",\\n\",\n",
    "    \"    \\\"    # 绘制曲线：设置颜色、线条宽度、标记点（增强辨识度）、label\\\\n\\\",\\n\",\n",
    "    \"    \\\"    ax.plot(x, arr, color=colors[i], linewidth=1.2, label=labels[i])\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_yscale('log')  # 核心修改：Y轴改为对数坐标\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.tick_params(direction='in')  # 刻度线向内（科研绘图规范）\\\\n\\\",\\n\",\n",
    "    \"    \\\"# -------------------------- 5. 细节优化（科研绘图必备） --------------------------\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 设置x轴、y轴标签（带字体大小）\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_xlabel('iteration', fontsize=14, )\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_ylabel('$E$-$E_0(MeV)$', fontsize=14, )\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 设置标题（按需修改）\\\\n\\\",\\n\",\n",
    "    \"    \\\"#ax.set_title('Comparison of 5 Groups of Arrays', fontsize=16, pad=20)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 添加图例（位置最优，避免遮挡数据）\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.legend(loc='best', fontsize=14, frameon=True, fancybox=True, shadow=False)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 添加网格（浅灰色虚线，辅助阅读，不喧宾夺主）\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.grid(True, linestyle='--', alpha=0.3, color='gray', linewidth=0.8)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 优化坐标轴：只保留左、下边框（科研绘图简洁风格）\\\\n\\\",\\n\",\n",
    "    \"    \\\"#ax.spines['top'].set_visible(False)\\\\n\\\",\\n\",\n",
    "    \"    \\\"#ax.spines['right'].set_visible(False)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 调整刻度范围（可选，根据数据自动适配）\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_xlim(0, max(len(arr) for arr in data_list) +50)  # x轴左右留边\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_ylim(np.min(np.concatenate(data_list))*0.1, np.max(np.concatenate(data_list)) *5)  # y轴上下留边\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 调整刻度标签大小\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.tick_params(axis='both', labelsize=11, length=3, width=1)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# -------------------------- 6. 保存图片（高分辨率，支持矢量图） --------------------------\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 保存为PNG（位图，适合预览）或PDF（矢量图，适合期刊发表）\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.tight_layout()  # 自动调整布局，避免标签被裁剪\\\\n\\\",\\n\",\n",
    "    \"    \\\"#fig.savefig('scientific_array_plot.png', dpi=300, bbox_inches='tight')  # PNG格式\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"#fig.savefig('scientific_array_plot.pdf', bbox_inches='tight',dpi=300)  # PDF矢量格式（推荐科研投稿用）\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 显示图像\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.show()\\\"\\n\",\n",
