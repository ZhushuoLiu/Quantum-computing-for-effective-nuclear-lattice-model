    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"import matplotlib.pyplot as plt\\\\n\\\",\\n\",\n",
    "    \"    \\\"import numpy as np\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 设置全局字体和绘图样式，适配科研论文要求\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['font.family'] = 'Arial'  # 科研常用无衬线字体\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['font.size'] = 12         # 基础字体大小\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['axes.linewidth'] = 1.2   # 坐标轴线条粗细\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['xtick.major.width'] = 1.2# x轴刻度线粗细\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['ytick.major.width'] = 1.2# y轴刻度线粗细\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['figure.dpi'] = 300       # 高清分辨率\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['savefig.dpi'] = 300\\\\n\\\",\\n\",\n",
    "    \"    \\\"plt.rcParams['savefig.bbox'] = 'tight' # 保存时去除多余空白\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 你的数据\\\\n\\\",\\n\",\n",
    "    \"    \\\"energy = [-24.444144614241324, -11.6502554744327, -5.518929090122524, -3.59904018025921, -2.224574038625467]\\\\n\\\",\\n\",\n",
    "    \"    \\\"L = [2, 3, 4, 5, 6]\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 转换为numpy数组（方便后续计算/绘图）\\\\n\\\",\\n\",\n",
    "    \"    \\\"energy = np.array(energy)\\\\n\\\",\\n\",\n",
    "    \"    \\\"L = np.array(L)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 创建画布（figsize适配科研论文版面，宽8cm，高6cm）\\\\n\\\",\\n\",\n",
    "    \"    \\\"fig, ax = plt.subplots(figsize=(8, 6))\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 绘制数据：散点+连线（科研常用组合）\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 散点（带边缘色，更清晰）\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 连线（平滑过渡）\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.plot(L, energy, color='#2E86AB', linewidth=1.5, linestyle='-', alpha=0.8)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.scatter(L, energy, color='black', s=20, linewidth=0.8, label='Energy')\\\\n\\\",\\n\",\n",
    "    \"    \\\"# ========== 新增：添加红色虚线（数值-2.224575） ==========\\\\n\\\",\\n\",\n",
    "    \"    \\\"reference_value = -2.224575\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 绘制水平参考线，x轴覆盖整个绘图范围，红色虚线\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.axhline(y=reference_value, color='red', linestyle='--', linewidth=1.2,\\\\n\\\",\\n\",\n",
    "    \"    \\\"           label=f'Reference: {reference_value}', alpha=0.9)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 设置坐标轴标签（带单位，科研绘图必备）\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_xlabel('L', fontsize=12, )  # a.u.为原子单位，可根据你的实际单位修改\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_ylabel('Energy (MeV)', fontsize=12, )        # 假设能量单位为eV，可替换为你的实际单位\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 设置坐标轴范围（优化视觉效果）\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_xlim(1.8, 6.2)  # x轴范围略大于数据范围\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 调整y轴范围，确保参考线完整显示\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_ylim(energy.min() - 2, reference_value + 1)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 设置刻度（整数刻度，更整洁）\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.set_xticks(L)  # x轴刻度与数据点对齐\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.tick_params(direction='in')  # 刻度线向内（科研绘图规范）\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 添加网格（辅助阅读数据）\\\\n\\\",\\n\",\n",
    "    \"    \\\"ax.grid(True, linestyle='--', alpha=0.3, linewidth=0.8)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"# 添加图例（位置优化，包含参考线标签）\\\\n\\\",\\n\",\n",
